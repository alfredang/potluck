# Application
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Public site URL — used for SEO canonical URLs, sitemap, robots, OG tags
NEXT_PUBLIC_SITE_URL=https://potluckhub.io

# Admin CMS (blog) — password to access /admin (set a strong value in production)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/homechef?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://default:password@host:6379

# JWT Secrets (generate with: openssl rand -base64 32)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# --- Checkout payment providers (web + iOS + Android all pay through
# --- https://<site>/api/checkout; set these in Coolify for production) ---

# Stripe (Singapore) — hosted Checkout Sessions
# Webhook endpoint: https://<site>/api/webhooks/stripe (event: checkout.session.completed)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal — Orders v2 REST. PAYPAL_MODE=sandbox|live
# Webhook endpoint: https://<site>/api/webhooks/paypal (events: PAYMENT.CAPTURE.*, CHECKOUT.ORDER.APPROVED)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
PAYPAL_WEBHOOK_ID=xxx

# HitPay — PayNow + card payment requests. HITPAY_MODE=sandbox|live
# Webhook is registered per-request automatically (https://<site>/api/webhooks/hitpay);
# HITPAY_SALT is in HitPay Dashboard → Payment Gateway → API Keys.
HITPAY_MODE=sandbox
HITPAY_API_KEY=xxx
HITPAY_SALT=xxx

# Stripe Price IDs for Chef Subscriptions
STRIPE_PRICE_BASIC=price_basic_monthly
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_UNLIMITED=price_unlimited_monthly

# OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
APPLE_CLIENT_ID=com.homechef.app
APPLE_TEAM_ID=xxx

# Google Maps
GOOGLE_MAPS_API_KEY=xxx

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=homechef-uploads
R2_PUBLIC_URL=https://your-r2-bucket.r2.dev

# Expo (for push notifications)
EXPO_ACCESS_TOKEN=xxx
